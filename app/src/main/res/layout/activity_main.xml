<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#1A1A2E">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="飞机大战"
        android:textSize="48sp"
        android:textColor="#E0E0E0"
        android:textStyle="bold"
        android:layout_marginBottom="40dp"/>

    <TextView
        android:id="@+id/tv_selected_difficulty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="已选：简单"
        android:textSize="18sp"
        android:textColor="#90CAF9"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="32dp">

        <Button android:id="@+id/btn_easy"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="简单" android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btn_normal"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="普通" android:layout_marginEnd="8dp"/>
        <Button android:id="@+id/btn_hard"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="困难"/>
    </LinearLayout>

    <Button
        android:id="@+id/btn_start"
        android:layout_width="240dp"
        android:layout_height="64dp"
        android:text="开始游戏"
        android:textSize="22sp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btn_leaderboard"
        android:layout_width="240dp"
        android:layout_height="56dp"
        android:text="排行榜"
        android:textSize="18sp"/>

</LinearLayout>
