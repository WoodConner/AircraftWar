<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="10dp"
    android:background="#16213E">

    <TextView android:id="@+id/tv_rank"
        android:layout_width="40dp" android:layout_height="wrap_content"
        android:textColor="#FFD700" android:textStyle="bold" android:textSize="16sp"/>
    <TextView android:id="@+id/tv_name"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="2" android:textColor="#E0E0E0" android:textSize="15sp"/>
    <TextView android:id="@+id/tv_score"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="2" android:textColor="#A5D6A7" android:textStyle="bold" android:textSize="15sp"/>
    <TextView android:id="@+id/tv_diff"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:textColor="#90CAF9" android:textSize="13sp"/>
    <TextView android:id="@+id/tv_time"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="2" android:textColor="#BDBDBD" android:textSize="12sp"/>
</LinearLayout>
